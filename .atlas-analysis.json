  "keyFeatures": [
    "JWT-based authentication with 1-hour token expiration",
    "Role-based access control (ADMIN, MEDICO, PACIENTE)",
    "Email verification for account activation",
    "Appointment booking and cancellation system",
    "Doctor and specialty management",
    "Real-time appointment availability tracking",
    "Optimistic locking for concurrent booking prevention",
    "Docker containerization with MySQL and phpMyAdmin"
